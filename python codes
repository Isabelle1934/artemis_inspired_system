#Objetivo final: Criar um sistema inteligente de simulação de missão espacial com análise de dados, automação e IA básica.
#Missão 1: Sistema de Status de Astronauta

boas_vindas = '========= Sistema de status de Astronautas - Nasa ========='

nome_astronauta = input("Insira seu nome: ")
idade = int(input("Insira sua idade: "))
nivel_treino = int(input("Insira seu nível de treinamento de 0-10: "))

print(boas_vindas)
print("Nome:", nome_astronauta)
print("Idade:", idade)
print("Nível de treino:", nivel_treino)

if nivel_treino >= 9:
    print('Você está apto para a missão!')
else:
    print('Você não está apto para a missão!')

#Missão 2: Calculadora de Combustível

distancia = float(input("Digite a distância da missão (km): "))
consumo_por_km = float(input("Digite o consumo da nave (kg por km): "))

def calcular_combustivel(distancia, consumo):
    return distancia * consumo

combustivel_total = calcular_combustivel(distancia, consumo_por_km)
print(f"Combustível necessário: {combustivel_total:.2f} kg")

#Missão 3: Checklist de Lançamento

print("===== CHECKLIST DE LANÇAMENTO =====")

itens = ["Combustível", "Clima", "Sistema Elétrico", "Pressão da Cabine"]

falhas = []

for item in itens:
    resposta = input(f"{item} está OK? (s/n): ").lower()
    
    if resposta != "s":
        falhas.append(item)

if len(falhas) == 0:
    print("Lançamento AUTORIZADO!")
else:
    print("Lançamento ABORTADO!")
    print("Falha nos seguintes sistemas:")
    
    for falha in falhas:
        print(f"- {falha}")
